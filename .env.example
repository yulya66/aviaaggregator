# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me-keep-secret

# Cron auth — generate with: openssl rand -hex 32
CRON_BEARER_TOKEN=replace-with-random-hex

# Admin area (/admin) — comma-separated emails allowed in. Unset = no admins.
ADMIN_EMAILS=you@example.com

# Travelpayouts — data API token + affiliate marker (required for L2/L3 cron)
TP_API_KEY=replace-me
TP_PARTNER_MARKER=replace-me
# TP_WEBHOOK_SECRET=   # Plan 5 (conversions webhook)

# Resend (Plan 3 onwards)
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
